#!/usr/bin/env python3
"""
03_qc_report.py — Comprehensive QC report for MOODS genome-wide motif scan.

Generates:
  1. Genome coverage analysis (total and per-motif)
  2. Promoter / intragenic / intergenic classification
  3. TSS distance distributions (per-motif and aggregate)
  4. Width-dependent expected-vs-observed analysis
  5. Palindrome detection and deduplication stats
  6. Publication-quality plots

Requires: bedtools, Python 3.8+, numpy, matplotlib, pandas

Usage:
    python 03_qc_report.py \
        --motif-dir /path/to/merged/per_motif \
        --merged-bed /path/to/merged/all_motifs_merged.bed.gz \
        --summary-tsv /path/to/merged/motif_hit_summary.tsv \
        --gtf /path/to/gencode.vM38.annotation.gtf.gz \
        --chrom-sizes /path/to/mm39.chrom.sizes \
        --meme /path/to/consensus_pwms.meme \
        --background /path/to/background.txt \
        --pvalue 1e-5 \
        --output-dir /path/to/qc_output
"""

import argparse
import os
import sys
import re
import subprocess
import tempfile
import gzip
from collections import defaultdict, Counter
from bisect import bisect_left

import numpy as np
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import matplotlib.ticker as ticker
from matplotlib.backends.backend_pdf import PdfPages
import pandas as pd


# ============================================================================
# Constants
# ============================================================================

STANDARD_CHROMS = set(f"chr{i}" for i in range(1, 20)) | {"chrX", "chrY"}


def chrom_sort_key(c):
    """Sort chromosomes numerically: chr1, chr2, ..., chr19, chrX, chrY."""
    c = c.replace("chr", "")
    if c.isdigit():
        return (0, int(c))
    elif c == "X":
        return (1, 0)
    elif c == "Y":
        return (1, 1)
    return (2, 0)


# ============================================================================
# Parsing
# ============================================================================

def parse_chrom_sizes(path):
    sizes = {}
    with open(path) as f:
        for line in f:
            parts = line.strip().split("\t")
            if len(parts) >= 2:
                sizes[parts[0]] = int(parts[1])
    return sizes


def parse_background(path):
    with open(path) as f:
        tokens = f.read().strip().split()
    bg = {}
    for i in range(0, len(tokens), 2):
        bg[tokens[i]] = float(tokens[i + 1])
    return [bg["A"], bg["C"], bg["G"], bg["T"]]


def parse_meme_file(meme_path):
    """
    Parse MEME file, return dict of motif_id -> {
        'width': int,
        'pfm': [[A probs], [C probs], [G probs], [T probs]]  (nucleotide x position)
    }
    """
    motifs = {}
    current_id = None
    current_matrix = []
    in_matrix = False
    expected_width = 0
    rows_read = 0

    with open(meme_path) as f:
        for line in f:
            line = line.strip()
            if line.startswith("MOTIF"):
                # Save previous
                if current_id and current_matrix:
                    motifs[current_id] = {
                        "width": len(current_matrix),
                        "pfm": _transpose(current_matrix),
                    }
                parts = line.split()
                current_id = parts[1].split(":")[0] if len(parts) > 1 else None
                current_matrix = []
                in_matrix = False
                rows_read = 0

            elif line.startswith("letter-probability matrix"):
                in_matrix = True
                match = re.search(r"\bw=\s*(\d+)", line)
                expected_width = int(match.group(1)) if match else 0
                rows_read = 0

            elif in_matrix and line and not line.startswith("URL") and not line.startswith("MOTIF"):
                values = line.split()
                if len(values) == 4:
                    try:
                        current_matrix.append([float(v) for v in values])
                        rows_read += 1
                        if expected_width > 0 and rows_read >= expected_width:
                            in_matrix = False
                    except ValueError:
                        in_matrix = False
                else:
                    in_matrix = False

    if current_id and current_matrix:
        motifs[current_id] = {
            "width": len(current_matrix),
            "pfm": _transpose(current_matrix),
        }

    return motifs


def _transpose(matrix):
    result = [[], [], [], []]
    for row in matrix:
        for nuc in range(4):
            result[nuc].append(row[nuc])
    return result


# ============================================================================
# Information content and expected p-value calculation
# ============================================================================

def compute_ic(pfm, bg):
    """
    Compute per-position and total information content (bits) for a PFM.

    IC_j = sum_b p(b,j) * log2(p(b,j) / bg(b))

    Returns (total_ic, per_position_ic_array)
    """
    width = len(pfm[0])
    ic_per_pos = np.zeros(width)
    for j in range(width):
        for b in range(4):
            p = pfm[b][j]
            if p > 0:
                ic_per_pos[j] += p * np.log2(p / bg[b])
    return float(np.sum(ic_per_pos)), ic_per_pos


def is_palindrome(pfm, tol=0.01):
    """
    Check if a PFM is (approximately) palindromic.

    A palindromic motif satisfies: pfm[b][j] ≈ pfm[complement(b)][w-1-j]
    where complement = {A↔T, C↔G} i.e. index {0↔3, 1↔2}
    """
    comp = {0: 3, 1: 2, 2: 1, 3: 0}
    w = len(pfm[0])
    for j in range(w):
        for b in range(4):
            if abs(pfm[b][j] - pfm[comp[b]][w - 1 - j]) > tol:
                return False
    return True


def estimate_n_passing_sequences(pfm, bg, threshold_score, pseudocount=0.001):
    """
    Estimate the number of distinct k-mers that would pass the score threshold.
    For short motifs, enumerate all possible sequences.
    For long motifs, use Monte Carlo sampling.

    Returns (n_passing, n_total, estimated_p)
    """
    import MOODS.tools
    w = len(pfm[0])

    if w <= 10:
        # Exact enumeration for short motifs
        # Build log-odds matrix
        log_odds = MOODS.tools.log_odds(pfm, bg, pseudocount)
        n_total = 4 ** w
        n_passing = 0
        bg_arr = np.array(bg)

        # Enumerate all k-mers
        for i in range(n_total):
            seq_indices = []
            val = i
            for _ in range(w):
                seq_indices.append(val % 4)
                val //= 4
            # Compute score
            score = sum(log_odds[b][j] for j, b in enumerate(seq_indices))
            # Compute probability of this k-mer under bg
            prob = 1.0
            for b in seq_indices:
                prob *= bg_arr[b]
            if score >= threshold_score:
                n_passing += 1

        # Estimated p-value: sum of bg probabilities of passing k-mers
        # More accurate than just n_passing/n_total for non-uniform bg
        p_est = 0.0
        for i in range(n_total):
            seq_indices = []
            val = i
            for _ in range(w):
                seq_indices.append(val % 4)
                val //= 4
            score = sum(log_odds[b][j] for j, b in enumerate(seq_indices))
            if score >= threshold_score:
                prob = 1.0
                for b in seq_indices:
                    prob *= bg_arr[b]
                p_est += prob

        return n_passing, n_total, p_est
    else:
        return None, 4 ** w, None


# ============================================================================
# GTF parsing for TSS and gene body annotations
# ============================================================================

def parse_gtf_for_annotations(gtf_path, tmpdir):
    """
    Parse GTF to create:
      1. TSS BED file (one per transcript, deduplicated to unique positions)
      2. Promoter BED file (TSS-1000 to TSS+200)
      3. Gene body BED file (protein_coding + lncRNA genes)

    Returns paths to the created BED files.
    """
    print("Parsing GTF for gene annotations...", file=sys.stderr)

    tss_path = os.path.join(tmpdir, "tss.bed")
    promoter_path = os.path.join(tmpdir, "promoters.bed")
    genebody_pc_path = os.path.join(tmpdir, "genebody_pc_lncrna.bed")
    all_genebody_path = os.path.join(tmpdir, "genebody_all.bed")

    tss_set = set()
    gene_bodies = []
    n_transcripts = 0

    opener = gzip.open if gtf_path.endswith(".gz") else open
    with opener(gtf_path, "rt") as f:
        for line in f:
            if line.startswith("#"):
                continue
            fields = line.strip().split("\t")
            if len(fields) < 9:
                continue

            chrom = fields[0]
            if chrom not in STANDARD_CHROMS:
                continue

            feature_type = fields[2]
            start = int(fields[3]) - 1  # GTF is 1-based; convert to 0-based
            end = int(fields[4])
            strand = fields[6]
            attrs = fields[8]

            # Extract gene_type
            gene_type_match = re.search(r'gene_type "([^"]+)"', attrs)
            gene_type = gene_type_match.group(1) if gene_type_match else ""

            # Extract gene_name
            gene_name_match = re.search(r'gene_name "([^"]+)"', attrs)
            gene_name = gene_name_match.group(1) if gene_name_match else ""

            if feature_type == "transcript":
                n_transcripts += 1
                # TSS = 5' end of transcript
                if strand == "+":
                    tss_pos = start
                else:
                    tss_pos = end  # 0-based half-open: TSS is at 'end' for - strand

                tss_set.add((chrom, tss_pos, strand, gene_name, gene_type))

            elif feature_type == "gene":
                gene_bodies.append((chrom, start, end, gene_name, strand, gene_type))

    print(f"  Found {n_transcripts:,} transcripts, "
          f"{len(tss_set):,} unique TSSs", file=sys.stderr)

    # Write TSS BED (sorted)
    tss_list = sorted(tss_set, key=lambda x: (chrom_sort_key(x[0]), x[1]))
    with open(tss_path, "w") as f:
        for chrom, pos, strand, gene_name, gene_type in tss_list:
            # BED: chrom, start, end (point = start, start+1), name, score, strand
            f.write(f"{chrom}\t{pos}\t{pos + 1}\t{gene_name}\t0\t{strand}\n")

    # Write promoter BED (TSS - 1000 to TSS + 200)
    with open(promoter_path, "w") as f:
        for chrom, pos, strand, gene_name, gene_type in tss_list:
            if strand == "+":
                prom_start = max(0, pos - 1000)
                prom_end = pos + 200
            else:
                prom_start = max(0, pos - 200)
                prom_end = pos + 1000
            f.write(f"{chrom}\t{prom_start}\t{prom_end}\t{gene_name}\t0\t{strand}\n")

    # Write gene body BED (protein_coding + lncRNA)
    pc_lnc_types = {"protein_coding", "lncRNA"}
    with open(genebody_pc_path, "w") as f:
        for chrom, start, end, name, strand, gtype in sorted(
            gene_bodies, key=lambda x: (chrom_sort_key(x[0]), x[1])
        ):
            if gtype in pc_lnc_types:
                f.write(f"{chrom}\t{start}\t{end}\t{name}\t0\t{strand}\n")

    # Write ALL gene bodies
    with open(all_genebody_path, "w") as f:
        for chrom, start, end, name, strand, gtype in sorted(
            gene_bodies, key=lambda x: (chrom_sort_key(x[0]), x[1])
        ):
            f.write(f"{chrom}\t{start}\t{end}\t{name}\t0\t{strand}\n")

    # Sort BED files with bedtools-compatible sort
    for path in [tss_path, promoter_path, genebody_pc_path, all_genebody_path]:
        _sort_bed_inplace(path)

    # Merge promoter regions (they overlap extensively)
    promoter_merged = os.path.join(tmpdir, "promoters_merged.bed")
    _run(f"bedtools merge -i {promoter_path} > {promoter_merged}")

    # Merge gene bodies
    genebody_merged = os.path.join(tmpdir, "genebody_merged.bed")
    _run(f"bedtools merge -i {genebody_pc_path} > {genebody_merged}")

    print(f"  Wrote TSS, promoter, and gene body BED files to {tmpdir}",
          file=sys.stderr)

    return {
        "tss": tss_path,
        "promoters": promoter_path,
        "promoters_merged": promoter_merged,
        "genebody_pc_lncrna": genebody_pc_path,
        "genebody_merged": genebody_merged,
        "genebody_all": all_genebody_path,
    }


# ============================================================================
# Bedtools helpers
# ============================================================================

def _run(cmd, check=True):
    """Run a shell command, return stdout."""
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    if check and result.returncode != 0:
        print(f"Command failed: {cmd}", file=sys.stderr)
        print(f"stderr: {result.stderr}", file=sys.stderr)
        raise RuntimeError(f"Command failed with exit code {result.returncode}")
    return result.stdout


def _sort_bed_inplace(path):
    """Sort a BED file by chrom, start."""
    tmp = path + ".tmp"
    _run(f"sort -k1,1 -k2,2n {path} > {tmp} && mv {tmp} {path}")


def compute_genome_coverage_bp(bed_path, is_gzipped=False):
    """
    Compute total covered base pairs from a BED file using bedtools merge.
    Returns total bp covered.
    """
    if is_gzipped:
        cmd = f"zcat {bed_path} | sort -k1,1 -k2,2n | bedtools merge -i - | awk '{{s += $3 - $2}} END {{print s}}'"
    else:
        cmd = f"sort -k1,1 -k2,2n {bed_path} | bedtools merge -i - | awk '{{s += $3 - $2}} END {{print s}}'"
    result = _run(cmd).strip()
    return int(result) if result else 0


def count_intersections(query_bed, subject_bed):
    """
    Count how many lines in query_bed overlap with subject_bed.
    Returns (n_overlapping, n_total).
    """
    # -u: report each query entry at most once if it overlaps
    cmd_overlap = f"bedtools intersect -u -a {query_bed} -b {subject_bed} | wc -l"
    cmd_total = f"wc -l < {query_bed}"
    n_overlap = int(_run(cmd_overlap).strip())
    n_total = int(_run(cmd_total).strip())
    return n_overlap, n_total


def classify_hits_genomic_context(motif_bed, promoter_bed, genebody_bed, tmpdir):
    """
    Classify hits as: promoter, intragenic (not promoter), or intergenic.

    Strategy:
      1. Intersect with promoters -> promoter hits
      2. Of remainder, intersect with gene bodies -> intragenic
      3. Remainder -> intergenic

    Returns (n_promoter, n_intragenic, n_intergenic, n_total)
    """
    base = os.path.basename(motif_bed).replace(".bed", "")
    tmp_not_promoter = os.path.join(tmpdir, f"_tmp_{base}_not_prom.bed")

    # Count promoter hits
    cmd_prom = f"bedtools intersect -u -a {motif_bed} -b {promoter_bed} | wc -l"
    n_promoter = int(_run(cmd_prom).strip())

    # Get non-promoter hits
    _run(f"bedtools intersect -v -a {motif_bed} -b {promoter_bed} > {tmp_not_promoter}")

    # Of non-promoter, count intragenic
    cmd_intra = f"bedtools intersect -u -a {tmp_not_promoter} -b {genebody_bed} | wc -l"
    n_intragenic = int(_run(cmd_intra).strip())

    n_total = int(_run(f"wc -l < {motif_bed}").strip())
    n_intergenic = n_total - n_promoter - n_intragenic

    # Cleanup
    if os.path.exists(tmp_not_promoter):
        os.remove(tmp_not_promoter)

    return n_promoter, n_intragenic, n_intergenic, n_total


# ============================================================================
# TSS distance computation (efficient, per-chromosome)
# ============================================================================

def load_tss_by_chrom(tss_bed_path):
    """
    Load TSS positions grouped by chromosome.
    Returns dict: {chrom: sorted numpy array of TSS positions}
    """
    tss_by_chrom = defaultdict(list)
    with open(tss_bed_path) as f:
        for line in f:
            fields = line.strip().split("\t")
            chrom = fields[0]
            pos = int(fields[1])
            tss_by_chrom[chrom].append(pos)

    return {c: np.sort(np.unique(np.array(v))) for c, v in tss_by_chrom.items()}


def compute_tss_distances_for_motif(motif_bed_path, tss_by_chrom, max_dist=500000,
                                    sample_n=None):
    """
    For each hit in a motif BED file, compute signed distance to nearest TSS.

    Convention: distance = hit_midpoint - nearest_tss_position
      positive = downstream of TSS (assuming + strand; unsigned for simplicity)
      We report absolute distance for the aggregate distribution.

    If sample_n is set, randomly sample that many hits for efficiency.

    Returns numpy array of distances (absolute values, capped at max_dist).
    """
    # First pass: count lines for sampling
    if sample_n is not None:
        n_lines = int(_run(f"wc -l < {motif_bed_path}").strip())
        if n_lines > sample_n:
            sample_rate = sample_n / n_lines
        else:
            sample_rate = 1.0
    else:
        sample_rate = 1.0

    distances = []
    rng = np.random.default_rng(42)

    with open(motif_bed_path) as f:
        for line in f:
            if sample_rate < 1.0 and rng.random() > sample_rate:
                continue

            fields = line.strip().split("\t")
            chrom = fields[0]
            start = int(fields[1])
            end = int(fields[2])
            midpoint = (start + end) // 2

            tss_arr = tss_by_chrom.get(chrom)
            if tss_arr is None or len(tss_arr) == 0:
                continue

            # Binary search for nearest TSS
            idx = bisect_left(tss_arr, midpoint)
            best_dist = float("inf")

            for candidate_idx in [idx - 1, idx]:
                if 0 <= candidate_idx < len(tss_arr):
                    d = abs(midpoint - tss_arr[candidate_idx])
                    if d < best_dist:
                        best_dist = d

            if best_dist <= max_dist:
                distances.append(best_dist)

    return np.array(distances)


# ============================================================================
# Main analysis routines
# ============================================================================

def analyze_genome_coverage(motif_dir, merged_bed, chrom_sizes, output_dir):
    """
    Compute genome coverage statistics.

    Returns:
      - total_bp_covered (all motifs merged)
      - per_motif_coverage: dict of motif_id -> bp_covered
    """
    print("\n=== Genome Coverage Analysis ===", file=sys.stderr)

    genome_size = sum(v for k, v in chrom_sizes.items() if k in STANDARD_CHROMS)
    print(f"  Effective genome size: {genome_size:,} bp", file=sys.stderr)

    # Total coverage (all motifs)
    print("  Computing total genome coverage (all motifs merged)...",
          file=sys.stderr)
    total_bp = compute_genome_coverage_bp(merged_bed, is_gzipped=True)
    pct = 100.0 * total_bp / genome_size
    print(f"  Total unique bp covered: {total_bp:,} ({pct:.2f}%)", file=sys.stderr)

    # Per-motif coverage
    print("  Computing per-motif coverage...", file=sys.stderr)
    per_motif_coverage = {}
    bed_files = sorted(
        f for f in os.listdir(motif_dir)
        if f.endswith(".bed") and not f.startswith(".")
    )

    for i, fname in enumerate(bed_files):
        motif_id = fname.replace(".bed", "")
        fpath = os.path.join(motif_dir, fname)
        bp = compute_genome_coverage_bp(fpath)
        per_motif_coverage[motif_id] = bp
        if (i + 1) % 50 == 0 or i == len(bed_files) - 1:
            print(f"    Processed {i + 1}/{len(bed_files)} motifs",
                  file=sys.stderr)

    return total_bp, per_motif_coverage, genome_size


def analyze_genomic_context(motif_dir, annotation_beds, output_dir, tmpdir,
                            motif_ids=None):
    """
    Classify motif hits by genomic context: promoter, intragenic, intergenic.

    Returns dict: motif_id -> (n_promoter, n_intragenic, n_intergenic, n_total)
    """
    print("\n=== Genomic Context Classification ===", file=sys.stderr)

    promoter_bed = annotation_beds["promoters_merged"]
    genebody_bed = annotation_beds["genebody_merged"]

    results = {}
    bed_files = sorted(
        f for f in os.listdir(motif_dir)
        if f.endswith(".bed") and not f.startswith(".")
    )

    if motif_ids is not None:
        bed_files = [f for f in bed_files if f.replace(".bed", "") in motif_ids]

    for i, fname in enumerate(bed_files):
        motif_id = fname.replace(".bed", "")
        fpath = os.path.join(motif_dir, fname)
        n_prom, n_intra, n_inter, n_total = classify_hits_genomic_context(
            fpath, promoter_bed, genebody_bed, tmpdir
        )
        results[motif_id] = (n_prom, n_intra, n_inter, n_total)
        if (i + 1) % 50 == 0 or i == len(bed_files) - 1:
            print(f"    Classified {i + 1}/{len(bed_files)} motifs",
                  file=sys.stderr)

    return results


def analyze_tss_distances(motif_dir, tss_bed, output_dir, motif_ids=None,
                          sample_per_motif=50000, max_dist=100000):
    """
    Compute TSS distance distributions per motif.

    Returns dict: motif_id -> numpy array of absolute distances
    """
    print("\n=== TSS Distance Analysis ===", file=sys.stderr)

    tss_by_chrom = load_tss_by_chrom(tss_bed)
    n_tss = sum(len(v) for v in tss_by_chrom.values())
    print(f"  Loaded {n_tss:,} unique TSS positions across "
          f"{len(tss_by_chrom)} chromosomes", file=sys.stderr)

    bed_files = sorted(
        f for f in os.listdir(motif_dir)
        if f.endswith(".bed") and not f.startswith(".")
    )

    if motif_ids is not None:
        bed_files = [f for f in bed_files if f.replace(".bed", "") in motif_ids]

    results = {}
    for i, fname in enumerate(bed_files):
        motif_id = fname.replace(".bed", "")
        fpath = os.path.join(motif_dir, fname)
        dists = compute_tss_distances_for_motif(
            fpath, tss_by_chrom,
            max_dist=max_dist,
            sample_n=sample_per_motif,
        )
        results[motif_id] = dists
        if (i + 1) % 50 == 0 or i == len(bed_files) - 1:
            print(f"    Processed {i + 1}/{len(bed_files)} motifs "
                  f"(sampled up to {sample_per_motif:,} hits each)",
                  file=sys.stderr)

    return results


# ============================================================================
# Plotting
# ============================================================================

def make_plots(summary_df, per_motif_coverage, context_results,
               tss_distances, genome_size, motif_info, pvalue,
               output_dir):
    """Generate all QC plots and save to a multi-page PDF."""
    pdf_path = os.path.join(output_dir, "qc_plots.pdf")
    print(f"\nGenerating plots → {pdf_path}", file=sys.stderr)

    with PdfPages(pdf_path) as pdf:

        # ---- Plot 1: Obs/Exp ratio vs motif width ----
        fig, ax = plt.subplots(figsize=(10, 6))
        widths = summary_df["width"].values
        obs_exp = summary_df["obs_over_exp"].values
        n_hits = summary_df["n_hits"].values

        sc = ax.scatter(widths, obs_exp, c=np.log10(n_hits + 1),
                        cmap="viridis", s=20, alpha=0.7, edgecolors="none")
        ax.set_xlabel("Motif width (bp)")
        ax.set_ylabel("Observed / Expected ratio")
        ax.set_title("Obs/Exp ratio by motif width\n"
                     "(color = log₁₀ hit count)")
        ax.set_yscale("log")
        ax.axhline(1, color="red", linestyle="--", alpha=0.5, label="Obs/Exp = 1")
        ax.axhline(10, color="orange", linestyle=":", alpha=0.5, label="Obs/Exp = 10")
        ax.axhline(0.1, color="orange", linestyle=":", alpha=0.5, label="Obs/Exp = 0.1")
        plt.colorbar(sc, label="log₁₀(n_hits)")
        ax.legend(fontsize=8)
        fig.tight_layout()
        pdf.savefig(fig)
        plt.close(fig)

        # ---- Plot 2: Information content vs hit count ----
        if "ic_total" in summary_df.columns:
            fig, ax = plt.subplots(figsize=(10, 6))
            ic = summary_df["ic_total"].values
            ax.scatter(ic, n_hits, c=widths, cmap="coolwarm", s=20,
                       alpha=0.7, edgecolors="none")
            ax.set_xlabel("Total information content (bits)")
            ax.set_ylabel("Number of hits (genome-wide)")
            ax.set_yscale("log")
            ax.set_title("Hit count vs. information content\n"
                         "(color = motif width)")
            plt.colorbar(
                plt.cm.ScalarMappable(
                    cmap="coolwarm",
                    norm=plt.Normalize(vmin=widths.min(), vmax=widths.max())
                ),
                ax=ax, label="Motif width (bp)"
            )
            fig.tight_layout()
            pdf.savefig(fig)
            plt.close(fig)

        # ---- Plot 3: Distribution of obs/exp ratios ----
        fig, ax = plt.subplots(figsize=(8, 5))
        ax.hist(np.log10(obs_exp), bins=50, color="steelblue", edgecolor="white",
                alpha=0.8)
        ax.axvline(0, color="red", linestyle="--", alpha=0.7, label="Obs/Exp = 1")
        ax.set_xlabel("log₁₀(Obs/Exp)")
        ax.set_ylabel("Number of motifs")
        ax.set_title("Distribution of Obs/Exp ratios across all motifs")
        ax.legend()
        fig.tight_layout()
        pdf.savefig(fig)
        plt.close(fig)

        # ---- Plot 4: Genome coverage per motif ----
        if per_motif_coverage:
            fig, axes = plt.subplots(1, 2, figsize=(14, 5))

            coverage_bp = np.array([per_motif_coverage.get(mid, 0)
                                    for mid in summary_df["motif_id"]])
            coverage_pct = 100.0 * coverage_bp / genome_size

            # Histogram of per-motif coverage
            ax = axes[0]
            ax.hist(coverage_pct, bins=50, color="teal", edgecolor="white", alpha=0.8)
            ax.set_xlabel("Genome coverage (%)")
            ax.set_ylabel("Number of motifs")
            ax.set_title("Per-motif genome coverage distribution")

            # Coverage vs width
            ax = axes[1]
            ax.scatter(summary_df["width"].values, coverage_pct,
                       s=20, alpha=0.6, color="teal", edgecolors="none")
            ax.set_xlabel("Motif width (bp)")
            ax.set_ylabel("Genome coverage (%)")
            ax.set_title("Genome coverage vs. motif width")

            fig.tight_layout()
            pdf.savefig(fig)
            plt.close(fig)

        # ---- Plot 5: Genomic context stacked bars (top 50 motifs by hit count) ----
        if context_results:
            fig, axes = plt.subplots(2, 1, figsize=(14, 10))

            # Aggregate pie chart
            ax = axes[0]
            total_prom = sum(v[0] for v in context_results.values())
            total_intra = sum(v[1] for v in context_results.values())
            total_inter = sum(v[2] for v in context_results.values())
            total_all = total_prom + total_intra + total_inter

            labels = [
                f"Promoter\n({total_prom:,}, {100*total_prom/total_all:.1f}%)",
                f"Intragenic\n({total_intra:,}, {100*total_intra/total_all:.1f}%)",
                f"Intergenic\n({total_inter:,}, {100*total_inter/total_all:.1f}%)",
            ]
            colors = ["#e74c3c", "#3498db", "#95a5a6"]
            ax.pie([total_prom, total_intra, total_inter],
                   labels=labels, colors=colors, autopct=None,
                   startangle=90, textprops={"fontsize": 9})
            ax.set_title("Aggregate genomic context of all motif hits")

            # Per-motif bar chart: top 50 by promoter enrichment
            ax = axes[1]
            # Compute promoter fraction for each motif
            motif_prom_frac = {}
            for mid, (np_, ni, nint, nt) in context_results.items():
                if nt > 0:
                    motif_prom_frac[mid] = np_ / nt
            # Sort by promoter fraction descending
            sorted_motifs = sorted(motif_prom_frac.keys(),
                                   key=lambda m: motif_prom_frac[m], reverse=True)[:50]

            prom_fracs = [context_results[m][0] / context_results[m][3]
                          for m in sorted_motifs]
            intra_fracs = [context_results[m][1] / context_results[m][3]
                           for m in sorted_motifs]
            inter_fracs = [context_results[m][2] / context_results[m][3]
                           for m in sorted_motifs]

            x = np.arange(len(sorted_motifs))
            ax.bar(x, prom_fracs, color="#e74c3c", label="Promoter")
            ax.bar(x, intra_fracs, bottom=prom_fracs, color="#3498db",
                   label="Intragenic")
            ax.bar(x, inter_fracs,
                   bottom=[p + i for p, i in zip(prom_fracs, intra_fracs)],
                   color="#95a5a6", label="Intergenic")
            ax.set_xticks(x)
            ax.set_xticklabels(sorted_motifs, rotation=90, fontsize=5)
            ax.set_ylabel("Fraction of hits")
            ax.set_title("Top 50 motifs by promoter enrichment")
            ax.legend(fontsize=8, loc="upper right")

            fig.tight_layout()
            pdf.savefig(fig)
            plt.close(fig)

        # ---- Plot 6: Promoter enrichment vs genome-wide hit count ----
        if context_results:
            fig, ax = plt.subplots(figsize=(10, 6))
            motifs_with_ctx = [m for m in summary_df["motif_id"]
                               if m in context_results]
            x_hits = [summary_df.loc[summary_df["motif_id"] == m, "n_hits"].values[0]
                      for m in motifs_with_ctx]
            y_prom_pct = [100 * context_results[m][0] / context_results[m][3]
                          if context_results[m][3] > 0 else 0
                          for m in motifs_with_ctx]

            ax.scatter(x_hits, y_prom_pct, s=15, alpha=0.6,
                       color="darkred", edgecolors="none")
            ax.set_xscale("log")
            ax.set_xlabel("Total hits (genome-wide)")
            ax.set_ylabel("% hits in promoter regions")
            ax.set_title("Promoter enrichment vs. hit count")
            fig.tight_layout()
            pdf.savefig(fig)
            plt.close(fig)

        # ---- Plot 7: TSS distance distributions ----
        if tss_distances:
            # Aggregate distribution
            fig, axes = plt.subplots(1, 2, figsize=(14, 5))

            all_dists = np.concatenate(list(tss_distances.values()))

            ax = axes[0]
            bins = np.linspace(0, 100000, 101)
            ax.hist(all_dists, bins=bins, color="darkblue", edgecolor="none",
                    alpha=0.7)
            ax.set_xlabel("Distance to nearest TSS (bp)")
            ax.set_ylabel("Count")
            ax.set_title("Aggregate TSS distance distribution\n(all motifs)")
            ax.xaxis.set_major_formatter(ticker.FuncFormatter(
                lambda x, _: f"{x/1000:.0f}k"))

            # Fraction within 1kb for each motif
            ax = axes[1]
            frac_within_1k = {}
            for mid, dists in tss_distances.items():
                if len(dists) > 0:
                    frac_within_1k[mid] = np.mean(dists <= 1000)

            fracs = sorted(frac_within_1k.values())
            ax.hist(fracs, bins=50, color="darkgreen", edgecolor="white", alpha=0.8)
            ax.set_xlabel("Fraction of hits within 1 kb of TSS")
            ax.set_ylabel("Number of motifs")
            ax.set_title("Per-motif: fraction of hits near TSSs")

            fig.tight_layout()
            pdf.savefig(fig)
            plt.close(fig)

            # Heatmap: TSS distance profile for top motifs by promoter enrichment
            if context_results:
                fig, ax = plt.subplots(figsize=(12, 8))
                # Select top 30 by fraction within 1kb
                top_motifs = sorted(frac_within_1k.keys(),
                                    key=lambda m: frac_within_1k[m],
                                    reverse=True)[:30]

                dist_bins = np.linspace(0, 50000, 51)
                heatmap_data = []
                labels = []
                for mid in top_motifs:
                    dists = tss_distances[mid]
                    if len(dists) > 0:
                        hist, _ = np.histogram(dists, bins=dist_bins, density=True)
                        heatmap_data.append(hist)
                        pct = 100 * frac_within_1k.get(mid, 0)
                        labels.append(f"{mid} ({pct:.0f}%)")

                if heatmap_data:
                    heatmap_data = np.array(heatmap_data)
                    im = ax.imshow(heatmap_data, aspect="auto", cmap="YlOrRd",
                                   interpolation="nearest")
                    ax.set_yticks(range(len(labels)))
                    ax.set_yticklabels(labels, fontsize=7)
                    # X-axis: distance bins
                    n_ticks = 6
                    tick_positions = np.linspace(0, len(dist_bins) - 2,
                                                 n_ticks).astype(int)
                    ax.set_xticks(tick_positions)
                    ax.set_xticklabels(
                        [f"{dist_bins[t]/1000:.0f}k" for t in tick_positions]
                    )
                    ax.set_xlabel("Distance to nearest TSS (bp)")
                    ax.set_title(
                        "TSS distance density for top 30 promoter-enriched motifs\n"
                        "(% = fraction within 1 kb)"
                    )
                    plt.colorbar(im, ax=ax, label="Density", shrink=0.8)
                    fig.tight_layout()

                pdf.savefig(fig)
                plt.close(fig)

        # ---- Plot 8: Palindrome analysis ----
        if "is_palindrome" in summary_df.columns:
            fig, ax = plt.subplots(figsize=(8, 5))
            pal = summary_df[summary_df["is_palindrome"]]
            nonpal = summary_df[~summary_df["is_palindrome"]]
            ax.hist(np.log10(nonpal["n_hits"]), bins=40, alpha=0.7,
                    color="steelblue", edgecolor="white",
                    label=f"Non-palindromic (n={len(nonpal)})")
            ax.hist(np.log10(pal["n_hits"]), bins=40, alpha=0.7,
                    color="coral", edgecolor="white",
                    label=f"Palindromic (n={len(pal)})")
            ax.set_xlabel("log₁₀(hit count)")
            ax.set_ylabel("Number of motifs")
            ax.set_title("Hit count distributions: palindromic vs. non-palindromic")
            ax.legend()
            fig.tight_layout()
            pdf.savefig(fig)
            plt.close(fig)

    print(f"  Saved all plots to {pdf_path}", file=sys.stderr)
    return pdf_path


# ============================================================================
# Summary table
# ============================================================================

def build_extended_summary(summary_tsv, motif_info, bg, per_motif_coverage,
                           context_results, tss_distances, genome_size):
    """
    Build an extended summary DataFrame with all computed metrics.
    """
    df = pd.read_csv(summary_tsv, sep="\t")

    # Add information content and palindrome flag
    ic_vals = []
    pal_flags = []
    for _, row in df.iterrows():
        mid = row["motif_id"]
        info = motif_info.get(mid)
        if info:
            ic_total, _ = compute_ic(info["pfm"], bg)
            ic_vals.append(ic_total)
            pal_flags.append(is_palindrome(info["pfm"]))
        else:
            ic_vals.append(np.nan)
            pal_flags.append(False)

    df["ic_total"] = ic_vals
    df["is_palindrome"] = pal_flags

    # Add genome coverage
    if per_motif_coverage:
        df["coverage_bp"] = df["motif_id"].map(per_motif_coverage).fillna(0).astype(int)
        df["coverage_pct"] = 100.0 * df["coverage_bp"] / genome_size

    # Add genomic context
    if context_results:
        df["n_promoter"] = df["motif_id"].map(
            lambda m: context_results.get(m, (0, 0, 0, 0))[0])
        df["n_intragenic"] = df["motif_id"].map(
            lambda m: context_results.get(m, (0, 0, 0, 0))[1])
        df["n_intergenic"] = df["motif_id"].map(
            lambda m: context_results.get(m, (0, 0, 0, 0))[2])
        df["pct_promoter"] = np.where(
            df["n_hits"] > 0,
            100.0 * df["n_promoter"] / df["n_hits"],
            0
        )

    # Add TSS distance stats
    if tss_distances:
        frac_1k = []
        median_dist = []
        for _, row in df.iterrows():
            mid = row["motif_id"]
            dists = tss_distances.get(mid)
            if dists is not None and len(dists) > 0:
                frac_1k.append(np.mean(dists <= 1000))
                median_dist.append(np.median(dists))
            else:
                frac_1k.append(np.nan)
                median_dist.append(np.nan)
        df["frac_within_1kb_tss"] = frac_1k
        df["median_tss_dist"] = median_dist

    return df


# ============================================================================
# Text report
# ============================================================================

def write_text_report(df, total_coverage_bp, genome_size, pvalue, bg, output_path):
    """Write a comprehensive text QC report."""
    lines = []
    lines.append("=" * 90)
    lines.append("MOODS GENOME-WIDE SCAN — COMPREHENSIVE QC REPORT")
    lines.append("=" * 90)
    lines.append("")

    # ---- Overview ----
    lines.append("OVERVIEW")
    lines.append("-" * 90)
    lines.append(f"  P-value threshold (requested):   {pvalue}")
    lines.append(f"  Effective genome size:            {genome_size:,} bp")
    lines.append(f"  Background: A={bg[0]:.4f} C={bg[1]:.4f} "
                 f"G={bg[2]:.4f} T={bg[3]:.4f}")
    lines.append(f"  Motif archetypes with hits:       {len(df)}")
    lines.append(f"  Total hits (genome-wide):         {df['n_hits'].sum():,}")
    lines.append("")

    if "is_palindrome" in df.columns:
        n_pal = df["is_palindrome"].sum()
        lines.append(f"  Palindromic motifs:               {n_pal} / {len(df)}")
        lines.append(f"    (palindromic motifs produce hits on both strands at")
        lines.append(f"     the same position — effective unique sites ≈ n_hits/2)")
    lines.append("")

    # ---- Genome coverage ----
    lines.append("GENOME COVERAGE")
    lines.append("-" * 90)
    if total_coverage_bp is not None:
        pct = 100.0 * total_coverage_bp / genome_size
        lines.append(f"  Total unique bp covered (all motifs): "
                     f"{total_coverage_bp:,} ({pct:.2f}%)")
    if "coverage_bp" in df.columns:
        lines.append(f"  Per-motif coverage range: "
                     f"{df['coverage_bp'].min():,} – {df['coverage_bp'].max():,} bp")
        lines.append(f"  Per-motif coverage range: "
                     f"{df['coverage_pct'].min():.4f}% – "
                     f"{df['coverage_pct'].max():.2f}%")
        lines.append(f"  Median per-motif coverage: "
                     f"{df['coverage_bp'].median():,.0f} bp "
                     f"({df['coverage_pct'].median():.4f}%)")
    lines.append("")

    # ---- Expected vs Observed (improved) ----
    lines.append("OBSERVED vs EXPECTED HIT COUNTS")
    lines.append("-" * 90)
    expected = pvalue * 2 * genome_size
    lines.append(f"  Naïve expected per motif (p × 2 × L):  {expected:,.0f}")
    lines.append(f"")
    lines.append(f"  NOTE: For short motifs (width ≤ ~8), the discrete score")
    lines.append(f"  distribution means the actual achieved p-value can be much")
    lines.append(f"  higher than the requested {pvalue}. This is why short motifs")
    lines.append(f"  show obs/exp >> 1. The 'expected' count assumes the requested")
    lines.append(f"  p-value equals the achieved p-value, which is not true for")
    lines.append(f"  short motifs.")
    lines.append("")

    # Motifs with obs/exp > 10 (likely short/low-IC motifs)
    high = df[df["obs_over_exp"] > 10].sort_values("obs_over_exp", ascending=False)
    lines.append(f"  Motifs with obs/exp > 10: {len(high)}")
    if len(high) > 0:
        lines.append(f"    {'Motif':<12} {'Width':>5} {'IC':>8} "
                     f"{'Hits':>12} {'Obs/Exp':>10} {'Palindrome':>10}")
        for _, row in high.head(20).iterrows():
            ic_str = f"{row.get('ic_total', 0):.1f}" if pd.notna(
                row.get("ic_total")) else "?"
            pal_str = "Yes" if row.get("is_palindrome", False) else "No"
            lines.append(f"    {row['motif_id']:<12} {row['width']:>5} "
                         f"{ic_str:>8} {row['n_hits']:>12,} "
                         f"{row['obs_over_exp']:>10.1f} {pal_str:>10}")
        if len(high) > 20:
            lines.append(f"    ... and {len(high) - 20} more")
    lines.append("")

    # Motifs with obs/exp < 0.1
    low = df[df["obs_over_exp"] < 0.1].sort_values("obs_over_exp")
    lines.append(f"  Motifs with obs/exp < 0.1: {len(low)}")
    if len(low) > 0:
        for _, row in low.head(10).iterrows():
            lines.append(f"    {row['motif_id']}: obs/exp = {row['obs_over_exp']:.4f} "
                         f"(width={row['width']}, hits={row['n_hits']:,})")
    lines.append("")

    # ---- Genomic context ----
    if "n_promoter" in df.columns:
        lines.append("GENOMIC CONTEXT (Promoter = TSS ± [-1000, +200])")
        lines.append("-" * 90)
        total_prom = df["n_promoter"].sum()
        total_intra = df["n_intragenic"].sum()
        total_inter = df["n_intergenic"].sum()
        total_all = total_prom + total_intra + total_inter
        lines.append(f"  Promoter:    {total_prom:>12,} "
                     f"({100*total_prom/total_all:.1f}%)")
        lines.append(f"  Intragenic:  {total_intra:>12,} "
                     f"({100*total_intra/total_all:.1f}%)")
        lines.append(f"  Intergenic:  {total_inter:>12,} "
                     f"({100*total_inter/total_all:.1f}%)")
        lines.append("")

        # Top promoter-enriched motifs
        top_prom = df.nlargest(20, "pct_promoter")
        lines.append("  Top 20 most promoter-enriched motifs:")
        lines.append(f"    {'Motif':<12} {'Width':>5} {'Hits':>10} "
                     f"{'%Promoter':>10} {'%Intragenic':>12} {'%Intergenic':>12}")
        for _, row in top_prom.iterrows():
            pct_intra = 100 * row["n_intragenic"] / row["n_hits"] if row["n_hits"] > 0 else 0
            pct_inter = 100 * row["n_intergenic"] / row["n_hits"] if row["n_hits"] > 0 else 0
            lines.append(f"    {row['motif_id']:<12} {row['width']:>5} "
                         f"{row['n_hits']:>10,} {row['pct_promoter']:>10.1f}% "
                         f"{pct_intra:>11.1f}% {pct_inter:>11.1f}%")
        lines.append("")

    # ---- TSS distance ----
    if "frac_within_1kb_tss" in df.columns:
        lines.append("TSS DISTANCE ANALYSIS")
        lines.append("-" * 90)
        lines.append(f"  Median fraction of hits within 1 kb of TSS: "
                     f"{df['frac_within_1kb_tss'].median():.3f}")
        lines.append(f"  Motifs with >20% of hits within 1 kb: "
                     f"{(df['frac_within_1kb_tss'] > 0.20).sum()}")
        lines.append(f"  Motifs with >50% of hits within 1 kb: "
                     f"{(df['frac_within_1kb_tss'] > 0.50).sum()}")
        lines.append("")

    # ---- Strand balance ----
    lines.append("STRAND BALANCE")
    lines.append("-" * 90)
    df["frac_plus"] = np.where(
        df["n_hits"] > 0, df["n_plus"] / df["n_hits"], 0.5)
    imbalanced = df[(df["n_hits"] > 100) &
                     ((df["frac_plus"] < 0.45) | (df["frac_plus"] > 0.55))]
    lines.append(f"  Motifs with strand imbalance (>55% or <45%): "
                 f"{len(imbalanced)}")
    # Perfect 50/50 (palindromes)
    perfect = df[(df["n_hits"] > 100) &
                  (df["n_plus"] == df["n_minus"])]
    lines.append(f"  Motifs with perfect strand balance (n+ == n−): "
                 f"{len(perfect)}")
    if len(perfect) > 0:
        lines.append("    (these are likely palindromic motifs)")
    lines.append("")

    # ---- Duplicate motif detection ----
    lines.append("POTENTIAL DUPLICATE MOTIFS")
    lines.append("-" * 90)
    hit_count_groups = df.groupby("n_hits")["motif_id"].apply(list)
    dups = {k: v for k, v in hit_count_groups.items() if len(v) > 1 and k > 1000}
    if dups:
        lines.append(f"  {len(dups)} groups of motifs share identical hit counts:")
        for count, motifs in sorted(dups.items(), key=lambda x: -x[0])[:10]:
            lines.append(f"    {count:,} hits: {', '.join(motifs)}")
        lines.append("    (identical counts + scores strongly suggest duplicate/")
        lines.append("     related entries in the motif database)")
    else:
        lines.append("  No obvious duplicates detected by hit count.")
    lines.append("")

    lines.append("=" * 90)
    lines.append("END OF REPORT")
    lines.append("=" * 90)

    report_text = "\n".join(lines)
    with open(output_path, "w") as f:
        f.write(report_text)

    return report_text


# ============================================================================
# Main
# ============================================================================

def main():
    parser = argparse.ArgumentParser(
        description="Comprehensive QC report for MOODS genome-wide motif scan",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--motif-dir", required=True,
                        help="Directory with per-motif BED files")
    parser.add_argument("--merged-bed", required=True,
                        help="Merged BED file (all_motifs_merged.bed.gz)")
    parser.add_argument("--summary-tsv", required=True,
                        help="motif_hit_summary.tsv from postprocess step")
    parser.add_argument("--gtf", required=True,
                        help="GENCODE GTF file (can be .gz)")
    parser.add_argument("--chrom-sizes", required=True,
                        help="UCSC chrom.sizes file")
    parser.add_argument("--meme", required=True,
                        help="MEME format motif file")
    parser.add_argument("--background", required=True,
                        help="Background frequencies file")
    parser.add_argument("--pvalue", type=float, default=1e-5,
                        help="P-value used for scanning (default: 1e-5)")
    parser.add_argument("--output-dir", required=True,
                        help="Output directory for QC results")

    # Performance options
    parser.add_argument("--skip-coverage", action="store_true",
                        help="Skip genome coverage analysis (slow for many motifs)")
    parser.add_argument("--skip-context", action="store_true",
                        help="Skip genomic context classification")
    parser.add_argument("--skip-tss-dist", action="store_true",
                        help="Skip TSS distance analysis")
    parser.add_argument("--tss-sample-n", type=int, default=50000,
                        help="Sample N hits per motif for TSS distance "
                             "(default: 50000)")
    parser.add_argument("--tss-max-dist", type=int, default=100000,
                        help="Max distance to TSS to report (default: 100000)")

    args = parser.parse_args()

    os.makedirs(args.output_dir, exist_ok=True)
    tmpdir = tempfile.mkdtemp(prefix="moods_qc_")
    print(f"Temp directory: {tmpdir}", file=sys.stderr)

    # ---- Load metadata ----
    print("Loading metadata...", file=sys.stderr)
    chrom_sizes = parse_chrom_sizes(args.chrom_sizes)
    genome_size = sum(v for k, v in chrom_sizes.items() if k in STANDARD_CHROMS)
    bg = parse_background(args.background)
    motif_info = parse_meme_file(args.meme)
    print(f"  {len(motif_info)} motifs from MEME file", file=sys.stderr)
    print(f"  Genome size: {genome_size:,} bp", file=sys.stderr)

    # ---- Parse GTF ----
    annotation_beds = parse_gtf_for_annotations(args.gtf, tmpdir)

    # ---- Genome coverage ----
    total_coverage_bp = None
    per_motif_coverage = {}
    if not args.skip_coverage:
        total_coverage_bp, per_motif_coverage, _ = analyze_genome_coverage(
            args.motif_dir, args.merged_bed, chrom_sizes, args.output_dir
        )
    else:
        print("\nSkipping genome coverage analysis (--skip-coverage)",
              file=sys.stderr)

    # ---- Genomic context ----
    context_results = {}
    if not args.skip_context:
        context_results = analyze_genomic_context(
            args.motif_dir, annotation_beds, args.output_dir, tmpdir
        )
    else:
        print("\nSkipping genomic context classification (--skip-context)",
              file=sys.stderr)

    # ---- TSS distances ----
    tss_distances = {}
    if not args.skip_tss_dist:
        tss_distances = analyze_tss_distances(
            args.motif_dir, annotation_beds["tss"], args.output_dir,
            sample_per_motif=args.tss_sample_n,
            max_dist=args.tss_max_dist,
        )
    else:
        print("\nSkipping TSS distance analysis (--skip-tss-dist)",
              file=sys.stderr)

    # ---- Build extended summary ----
    print("\nBuilding extended summary...", file=sys.stderr)
    df = build_extended_summary(
        args.summary_tsv, motif_info, bg,
        per_motif_coverage, context_results, tss_distances,
        genome_size,
    )

    # Write extended summary
    ext_summary_path = os.path.join(args.output_dir, "motif_summary_extended.tsv")
    df.to_csv(ext_summary_path, sep="\t", index=False)
    print(f"  Wrote extended summary: {ext_summary_path}", file=sys.stderr)

    # ---- Text report ----
    report_path = os.path.join(args.output_dir, "qc_report_comprehensive.txt")
    write_text_report(df, total_coverage_bp, genome_size, args.pvalue, bg,
                      report_path)
    print(f"  Wrote text report: {report_path}", file=sys.stderr)

    # ---- Plots ----
    make_plots(df, per_motif_coverage, context_results, tss_distances,
               genome_size, motif_info, args.pvalue, args.output_dir)

    # Cleanup tmpdir
    import shutil
    shutil.rmtree(tmpdir, ignore_errors=True)

    print("\nDone!", file=sys.stderr)


if __name__ == "__main__":
    main()